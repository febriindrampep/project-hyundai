<script type="text/javascript">

/*-------------------------commonGa4.js Start----------------------------------------*/


window.HMCdataLayer = window.HMCdataLayer || [];      // GA4을 위한 data layer

// ga4Seperator
const ga4Sep = "||";

var field_name = ""; //[2024.12.04 이동욱] GT  : GA4 demo   
var pagetitleGA4 = "";
var pipProductName = "" ;
var fileTypeList = ["pdf", "jpg", "xlsx", "doc", "docx", "png", "gif"];
var beforeUnloadChk = "";
var focusChk = "";
var contentPath = XSS_Check($(location).attr('pathname'));
if(contentPath.indexOf('/content/hyundai') != -1){
    contentPath = contentPath.replace('/content/hyundai/', '').replace('.html', '').split('/');
} else {
    contentPath = contentPath.substring(1,contentPath.length).replace('.html', '').split('/');
} 
var errorChkPath = "";    

let ga4Path = location.pathname;
let ga4Path2 = ga4Path.replace('.html', '').split('/');
let ga4Page = [];
let ga4PageType;
let ga4PageTemplate = "";
let ga4PageUrl = location.href;
let ga4LinkMap = new Map();
let ga4CustomerMap = new Map();
let ga4PageName = "";


/**
 * Param..
 *   gaEvent : event 구분자
 *   gaEventName : event 구분 명
 *   gaKeyArr : key 모음
 *   gaValueArr : value 모음
 */
function ga4_track(gaEvent, gaEventName, gaKeyArr, gaValueArr) {
    let gaDataLayer = new Map();
    
    gaDataLayer.set("event", gaEvent);
    gaDataLayer.set("eventName", gaEventName);


    for (let ii = 0; ii < gaKeyArr.length; ii++) {
        gaDataLayer.set(gaKeyArr[ii], gaValueArr[ii]);
        
    }

    console.log("---- ---- ---- ---- ---- ---- ---- ---- ");
    console.log("---- ---- ---- ---- ga4_track ---- ---- ---- ---- ");
    console.log(gaDataLayer);
    let resultObj = JSON.parse(JSON.stringify(gaDataLayer,ga4_Replacer));
    let resultStr = JSON.stringify(gaDataLayer,ga4_Replacer);
    console.log(resultStr);
   
  HMCdataLayer.push(resultObj);
}

//맵을 문자로
function ga4_Replacer(key, value) {
  if(value instanceof Map) { //형식 확인
    return Object.fromEntries(value); //entries 함수를 통해 배열로 변경(이중)
  } else {
    return value;
  }
}

//자동으로 데이터를 양식에 맞게 만들어 주는 함수
function ga4ResultMapForAuto(objMap) {
    // replace 적용 제외 키 목록
    var NO_REPLACE_KEYS = new Set(["models_name", "models_code", "page_country", "page_global_code"]);

    // 값 정규화: 빈값 처리 및 replace 적용 여부 결정
    function resolveVal(key, val) {
        if (val == null || val === "undefined" || (val === "" && typeof val === "string")) return "";
        if (typeof val !== "string" || NO_REPLACE_KEYS.has(key)) return val;
        return ga4ReplaceCase(val);
    }

    // 중첩 Map에서 해당 key의 Map을 보장하며 반환
    function ensureMap(map, key) {
        if (map.get(key) === undefined) map.set(key, new Map());
        return map.get(key);
    }

    let resultMap = new Map();
    resultMap.set("event", "ga_event");
    resultMap.set("eventName", "click_event");

    let logStr = "";

    for (let key of objMap.keys()) {
        if (key === "data_link_page") continue; // data_link_page 제외

        let k   = key.split('_');
        let val = resolveVal(key, objMap.get(key));

        logStr += key + " : " + val + "\n";

        if (k.length === 1) {
            resultMap.set(k[0], val);
        } else if (k.length === 2) {
            ensureMap(resultMap, k[0]).set(k[1], val);
        } else if (k.length === 3) {
            ensureMap(ensureMap(resultMap, k[0]), k[1]).set(k[2], val);
        } else if (k.length === 4) {
            ensureMap(ensureMap(ensureMap(resultMap, k[0]), k[1]), k[2]).set(k[3], val);
        }
    }

    console.log("---- ---- ---- ---- ---- ---- ---- ---- ");
    console.log("---- ---- ---- ---- ga4ResultMapForAuto ---- ---- ---- ---- ");
    console.log(resultMap);
    console.log(logStr);

    HMCdataLayer.push(JSON.parse(JSON.stringify(resultMap, ga4_Replacer)));
}

// 헬퍼: Object literal 를 Map으로 변환 후 ga4ResultMapForAuto 호출
function fireGA4Auto(params) {
    ga4ResultMapForAuto(new Map(Object.entries(params)));
}



$(document).ready(function() {
    
    $(".formListWrap dd").on("click", function() {
        let findFormTit = ga4HtmlNullChk($(this).parent().find(".formTit").text());
        let findRequire = ga4HtmlNullChk($(this).parent().find(".formTit .require").text());

        if($(this).find("input").length != 0 || $(this).find("textarea").length != 0 || $(this).find("select option:selected").length != 0){
            field_name = findFormTit.slice(0, findFormTit.lastIndexOf(findRequire));
        }

    }); 
    
    
    // 경로 파싱: content/hyundai 포함 여부에 따라 슬라이스 기준 결정
    var isContent = ga4Path.indexOf('content/hyundai') > -1;
    var sliceFrom = isContent ? 5 : 3;
    var offset    = isContent ? 5 : 3;

    ga4Page = ga4Path2.slice(sliceFrom).map(function(seg) { return seg.replace('.html', ''); });
    if (ga4Page.length === 0) ga4Page[0] = 'home';
    pagetitleGA4 = page[0] === "main" ? "home" : page[(ga4Path2.length - 1) - offset];

    // 디바이스 타입
    ga4PageType = window.innerWidth > 1120 ? 'pc' : 'mo';

    // 페이지 이름 / 콘텐츠 그룹 구성
    var tempGa4PageName      = ga4Page.join(':');
    var tempGa4ContentGroup  = (ga4Page.length > 1 ? ga4Page.slice(0, -1) : ga4Page).join(':');
    var tempGa4PageCountry   = window.hmc.COUNTRY;
    var tempGa4PageGlobalCode    = "";
    var tempGa4PageContentType   = ga4Page[ga4Page.length - 1];

    // 국가코드 → ISO코드 / 글로벌코드 매핑
    var countryCodeMap = {
        almajdouie: { country: "SA", globalCode: "KSA(Dammam)" },
        mynaghi:    { country: "SA", globalCode: "KSA(Jeddah)" },
        wallan:     { country: "SA", globalCode: "KSA(Riyadh)" },
        th:         { country: "TH", globalCode: "HMT" },
        ph:         { country: "PH", globalCode: "HMPH" },
        kz:         { country: "KZ", globalCode: "KAZ" }
    };
    var countryInfo = countryCodeMap[tempGa4PageCountry];
    if (countryInfo) {
        tempGa4PageCountry    = countryInfo.country;
        tempGa4PageGlobalCode = countryInfo.globalCode;
    }

    // 콘텐츠 타입 결정
    if (ga4Page[0] === "find-a-car") {
        tempGa4PageContentType = "vehicle";
    } else if (ga4Page[0] === "build-a-car") {
        tempGa4PageContentType = ga4Page[1].replaceAll("-", "_");
    }
    var VALID_CONTENT_TYPES = ["home", "vehicle", "search", "find_a_dealer", "request_a_test_drive", "request_a_quote", "special_offers"];
    if (!VALID_CONTENT_TYPES.includes(tempGa4PageContentType)) {
        tempGa4PageContentType = "other";
    }

    // 로그인 상태 확인 (th 전용)
    var userLoggedIn = "false";
    if (hmc.COUNTRY === "th") {
        var loginCookie = ComUtils.cookieGet('cookie_BuyOnline_th');
        if (loginCookie && loginCookie !== 'undefined') userLoggedIn = "true";
    }

    // page_view 이벤트 Map 구성
    var ga4PageViewPageMap = new Map([
        ["event",             "ga_page"],
        ["eventName",         "page_view"],
        ["contentGroup",      tempGa4ContentGroup],
        ["page_name",         tempGa4PageName],  // TO-DO
        ["page_contentType",  tempGa4PageContentType],
        ["page_language",     window.hmc.LANGUAGE],
        ["page_country",      tempGa4PageCountry],
        ["page_type",         "brand"],
        ["page_visit_device", ga4PageType],
        ["page_global_code",  tempGa4PageGlobalCode],
        ["user_loggedIn",     userLoggedIn],
        ["user_visit_device", ga4PageType]
    ]);

    // page depth 동적 세팅 (최대 4depth, 마지막 항목 제외)
    for (var d = 0; d < Math.min(ga4Page.length - 1, 4); d++) {
        ga4PageViewPageMap.set("page_" + (d + 1) + "depth", ga4Page[d]);
    }

    ga4ResultMapForAuto(ga4PageViewPageMap);
});

