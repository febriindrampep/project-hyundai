                    dyContextTemp = { type: dyContType, data: dyPrdData, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                }
                else if (dyContType=='CATEGORY' && pageDY.length > 3) {
                    DY.recommendationContext = { type: dyContType, data: dyPrdData, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                    dyContextTemp = { type: dyContType, data: dyPrdData, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                }
                else {
                    DY.recommendationContext = { type: dyContType, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                    dyContextTemp = { type: dyContType, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                }
            }
            
            initDY();
