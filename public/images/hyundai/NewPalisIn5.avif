<script type="text/javascript">

    let _ajaxCount = 0;
    let _isAjaxError = false;
    let _settingsUrlStarted = false;
    let chkDetail = false;
    const newsPatterns= [ /\/hyundai-story\/news[\/\.].+/i, /\/sobre-hyundai\/noticias[\/\.].+/i ];
    let pathname = window.location.pathname;
    let settingsUrl = "/wsvc/template_en/spa/common/news/newsList.html";

    if (newsPatterns.some(pattern => pattern.test(pathname))) {
        chkDetail = true;
    }
    if(chkDetail){
        //페이지 로드 시 로딩바 노출
        document.addEventListener('DOMContentLoaded', function() {
            showLoading(true);
        });

        $(document).ajaxSend(function (event, xhr, settings) {
            if (settings.url==settingsUrl) {
                _settingsUrlStarted = true;
                _ajaxCount++;
            }
        });

        $(document).ajaxError(function(event, xhr, settings, thrownError) {
            if (settings.url==settingsUrl) {
                _isAjaxError = true;
                console.log('AJAX 에러 발생!');
                console.log('상태코드:', xhr.status);
                console.log('에러메시지:', thrownError);
            }
        });

        $(document).ajaxComplete(function (event, xhr, settings) {

            if (settings.url==settingsUrl) {
                _ajaxCount = Math.max(0, _ajaxCount - 1);
                if (_isAjaxError) {
                    _isAjaxError = false;
                    if (_ajaxCount === 0) {
                        showLoading(false);
                    }
                    return;
                }

                if (_ajaxCount === 0) {
                    showLoading(false);
                }
            }

        });
        //settingsUrl AJAX 없을 경우 페이지 로딩 완료 시 로딩바 제거
        window.addEventListener('load', function() {
            if (!_settingsUrlStarted) {
                showLoading(false);
            }
        });
    }
</script>



<script defer="" type="text/javascript">
  var dySessionId = ""; //dynamicyield 미사용 국가를 위한 글로벌 변수
</script>





    
    
        <script>
            dySessionId = "8777752";
            /*
            * expires   : 쿠키 만료를 일단위로 설정 [ex:365] 
            * path      : 쿠키가 적용되는 페이지 경로. 사이트 전체 페이지에 적용 시 ['/']
            * domain    : 쿠키가 적용될 도메인 디폴트가 쿠키가 만들어진 도메인['domain.com']
            * secure    : 디폴트는 false, true로 설정하면 쿠키전송은 https 프로토콜로만 가능
            * raw       : 디폴트는 false이다 false 일 경우는 쿠키는 생성되거나 읽을 떄 기본적으로 인코딩/디코딩을 (encodeURIComponent / decodeURIComponent 이용)
            */
        </script>
        
        <script>
            var path_DY = location.pathname;
            var path2_DY = path_DY.split('/');
            var page_DY = [];
            var pageUrl_DY = location.href;
    
            /* [2021.10.06 최재영] GT : START  - dynamicyield target 변수 추가 */
            var dyContType      = "HOMEPAGE"; // default
            var dyLang          = "";
            var dyContextTemp   = {};
            var dyPrdData       = [];
            var pageDY          = [];
            var dyBPStepFirst   = false;
            var dyBPStepCarCd   = "";
    
            window.DY = window.DY || {};
            /* [2021.10.06 최재영] GT : END    - dynamicyield target 변수 추가 */
    
            if (path_DY.indexOf('content/hyundai') > -1) {
                for (var i = 4; i < path2_DY.length; i++) {
                    if (i == 4) {
                        page_DY[0] = 'main';
                    } else {
                        page_DY[i - 5] = path2_DY[i].replace('.html', '');
                    }
                }
            } else {
                for (var i = 2; i < path2_DY.length; i++) {
                    if (i == 2) {
                        page_DY[0] = 'main';
                    } else {
                        page_DY[i - 3] = path2_DY[i].replace('.html', '');
                    }
                }
            }
            // [2018.11.23:전영우] GT : End - Adobe Analytics 수정
                
            /* [2021.10.06 최재영] GT : START    - dynamicyield target init function 추가 */
            function setDYContentType(){
                dyPrdData = [];
                if (pageDY[2] == 'main') {
                    dyContType = "HOMEPAGE"; 
                 }
                 else if (pageDY[2] == 'find-a-car') {
                     dyContType = "PRODUCT";
                     if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle.suv") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("suv");
                     }
                     else if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle.eco") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("ev");
                     }
                     else if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle.mpv") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("mpv");
                     }
                     else if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle.crossover") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("crossover");
                     }
                     else if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle.commercial") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("commercial");
                     }
                     else if (pageUrl_DY.indexOf("find-a-car/select-a-vehicle") > -1) {
                         dyContType = "CATEGORY";
                         dyPrdData.push("suv","ev","mpv","crossover", "commercial");
                     }
                     else if (page_DY.length > 3) {
                         dyPrdData.push(page_DY[3]);
                     }

                 }
                 else if (pageDY[2] == 'build-a-car') {
                     if (pageUrl_DY.indexOf("build-a-car/build-and-price/build-and-price-summary") > -1) {
                         dyContType = "CART";
                         var params = location.search.substr(location.search.indexOf("?") + 1);
                         var sname = "prodcd";
                         params = params.split("&");
                         for (var i = 0; i < params.length; i++) {
                             temp = params[i].split("=");
                             if ([temp[0]] == sname) { 
                                 dyPrdData.push(temp[1]);
                                 dyBPStepCarCd = temp[1];
                                 dyBPStepFirst = true;
                             }
                         }
                     }
                     else if (pageUrl_DY.indexOf("/build-and-price-all-vehicles") > -1) {
                         dyContType = "OTHER";
                     }
                     else if (pageUrl_DY.indexOf("build-a-car/build-and-price/build-and-price-steps") > -1) {
                         dyContType = "PRODUCT";
                         var params = location.search.substr(location.search.indexOf("?") + 1);
                         var sname = "productCode";
                         params = params.split("&");
                         for (var i = 0; i < params.length; i++) {
                             temp = params[i].split("=");
                             if ([temp[0]] == sname) { 
                                 dyPrdData.push(temp[1]);
                                 dyBPStepCarCd = temp[1];
                                 dyBPStepFirst = true;
                             }
                         }
                     }
                     else {
                         dyContType = "OTHER";
                     }
                 }
                 else {
                     dyContType = "OTHER"; 
                 }
            }

            /* [2021.12.21 최재영] GT : START  - dynamicyield [build-and-price] 통합 전송 로직 추가 */
            function sendDySpa( param ) {
                if( !$.isEmptyObject(param) ){
                    if( param["type"] == "CATEGORY" ){
                        dyBPData = [];
                        if( param["name"] == "" ){
                            dyBPData.push("All Cars");
                        }else{
                            dyBPData.push(param["name"]);
                        }
                        /*if( param["name"] =="section2" ){
                            dyBPData.push("Private");
                        }else if( param["name"] =="section3" ){
                            dyBPData.push("Crossovers");
                        }else if( param["name"] =="section4" ){
                            dyBPData.push("Commercial");
                        }else{
                            dyBPData.push("All Cars");
                        }*/
                        DY.API("spa", {
                            context: { type: param["type"] , data: dyBPData, lng: hmc.LANGUAGE + "_" + hmc.COUNTRY.toUpperCase() },
                            url: location.href,
                            countAsPageview: false
                        });
                    }else if( param["type"] == "PRODUCT" ){
                        DY.API("spa", {
                            context: { type: param["type"] , data: [ param["productCode"] ], lng: hmc.LANGUAGE + "_" + hmc.COUNTRY.toUpperCase() },
                            url: location.href + "&" + param["name"],
                            countAsPageview: false
                        });

                        DY.API("event", {
                            name: "Configurator_step1",
                            properties: {
                                carId : param["productCode"]
                            }
                        });
                    }
                }
            }
            /* [2021.12.21 최재영] GT : END    - dynamicyield [build-and-price] 통합 전송 로직 추가 */
            
            function initDY(){
    
                if (path_DY.indexOf('content/hyundai') > -1) {
                    for (var i = 2; i < path2_DY.length; i++) {
                        if (i == 2) {
                            pageDY[2] = 'main';
                        } else {
                            pageDY[i - 3] = path2_DY[i].replace('.html', '');
                        }
                    }
                } else {
                    for (var i = 0; i < path2_DY.length; i++) {
                        if (i == 0) {
                            pageDY[2] = 'main';
                        } else {
                            pageDY[i - 1] = path2_DY[i].replace('.html', '');
                        }
                    }
                }
                
                setDYContentType();
                
                if (dyContType=='PRODUCT' && pageDY.length > 3) {
                    if (dyBPStepFirst) {
                        DY.recommendationContext = { type: dyContType, data: [dyBPStepCarCd], lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                        dyContextTemp = { type: dyContType, data: dyPrdData, lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
                    }
                    else {
                        DY.recommendationContext = { type: dyContType, data: [pageDY[3]], lng: pageDY[1] + "_" +  pageDY[0].toUpperCase()}
