    });
}

//셀렉터조회시 null값 방지
function ga4HtmlNullChk(obj){
    let rtnStr = "";
    if(!obj){
        rtnStr = "";
    }else{
        rtnStr = obj;
    }
    return rtnStr
}

//impressions의 경우는 현재의 컴포넌트이름을 data_link_action에 직접 남길수 없어서 onload 이벤트를 활용하여 처리
function ga4ActionData(act){
    var rtnStr = "";
    rtnStr = ga4GetComponentNameOnClick(act);
    act.setAttribute("data_link_action",rtnStr);
}

